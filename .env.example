# Environment Variables for Hari Automobiles Website - Netlify Deployment
# Copy this file to .env and fill in your actual values
# For Netlify: Add these variables in Site Settings → Build & Deploy → Environment

# Google Gemini API (if used for AI features)
VITE_GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here
GEMINI_API_KEY=your_google_genai_api_key_here

# Build Environment
NODE_ENV=production

# API Endpoints (if applicable)
VITE_API_BASE_URL=https://api.example.com

# Analytics (if applicable)
VITE_ANALYTICS_ID=your_analytics_id_here

# Feature Flags
VITE_ENABLE_BOOKING=true
VITE_ENABLE_CHAT=true

# App URL (for self-referential links, OAuth callbacks)
APP_URL=https://your-domain.netlify.app
